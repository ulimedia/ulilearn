# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://app.ulilearn.academy
NEXT_PUBLIC_SITE_URL=https://ulilearn.academy
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# Pooled connection string used by Prisma runtime
DATABASE_URL=
# Direct connection for Prisma migrations (unpooled)
DIRECT_URL=

# -----------------------------------------------------------------------------
# Supabase (Auth + Storage)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Stripe (billing primary)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_ANNUAL=

# -----------------------------------------------------------------------------
# PayPal (billing secondary, one-shot)
# -----------------------------------------------------------------------------
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_ENV=sandbox

# -----------------------------------------------------------------------------
# Vimeo (video hosting)
# -----------------------------------------------------------------------------
VIMEO_ACCESS_TOKEN=
VIMEO_CLIENT_ID=
VIMEO_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Resend (transactional email)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM="Ulilearn <hello@ulilearn.academy>"

# -----------------------------------------------------------------------------
# Upstash Redis (rate limiting)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=app.ulilearn.academy

# -----------------------------------------------------------------------------
# Sentry (error tracking)
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Lead magnet: Instagram profile analysis (Anthropic Claude)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_COST_CENTS_PER_WEEK=5000

# Cloudflare Turnstile (anti-bot on public lead form)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Rate limiting (Upstash Redis required in prod — see UPSTASH_* above)
LEAD_MAGNET_RATE_LIMIT_PER_IP_HOUR=5
LEAD_MAGNET_RATE_LIMIT_PER_EMAIL_DAY=3

# Where the CTA banner in the analysis page points (legacy Kajabi for now)
LEAD_MAGNET_KAJABI_CTA_URL=https://ulilearn.academy/catalogo/abbonamento/ulilearn-plus/
